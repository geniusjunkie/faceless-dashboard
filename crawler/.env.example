# YouTube API key — get yours free at https://console.cloud.google.com
# Steps: New Project → Enable "YouTube Data API v3" → Credentials → Create API Key
YOUTUBE_API_KEY=YOUR_API_KEY_HERE

# Optional: how many days back to search for new channels (default: 120)
MAX_CHANNEL_AGE_DAYS=120

# Optional: minimum monthly views for a channel to appear (default: 50000)
MIN_MONTHLY_VIEWS=50000

# Optional: auto git push after crawl? (true/false, default: false)
AUTO_PUSH=false
